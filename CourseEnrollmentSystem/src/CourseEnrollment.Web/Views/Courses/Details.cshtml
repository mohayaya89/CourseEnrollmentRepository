@using CourseEnrollment.Application.Features.Courses.Queries.GetCourseById
@using CourseEnrollment.Domain.Enums
@model CourseEnrollment.Application.Features.Courses.Queries.GetCourseById.CourseDto

@{
    ViewData["Title"] = "Course Details";
}

<h2>@Model.Title</h2>

<hr />

<div>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Capacity:</strong> @Model.Capacity</p>
    <p><strong>Active Enrollments:</strong> @Model.ActiveEnrollments</p>
</div>

<hr />

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<!-- Error Message -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<hr />

<!-- Enroll Form -->
@if (Model.Status == CourseStatus.Open)
{
    <form 
        asp-action="Enroll"
        asp-controller="Courses"
        asp-route-id="@Model.Id"
        method="post">

        @Html.AntiForgeryToken()

        <button type="submit" class="btn btn-success">
            Enroll Now
        </button>
    </form>
}
else
{
    <button class="btn btn-secondary" disabled>
        Enrollment Closed
    </button>
}