@page "/courses/create"
@inject CourseApiService Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Create Course</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

<MudText Typo="Typo.h4" GutterBottom="true">Create New Course</MudText>

<MudPaper Class="pa-6" Elevation="2" Style="max-width: 600px;">
    <MudForm @ref="_form" @bind-IsValid="_isValid">

        <MudTextField @bind-Value="_model.Title"
                      Label="Course Title"
                      Required="true"
                      RequiredError="Title is required."
                      MaxLength="200"
                      Counter="200"
                      Class="mb-4" />

        <MudNumericField @bind-Value="_model.Capacity"
                         Label="Capacity"
                         Required="true"
                         Min="1"
                         RequiredError="Capacity must be at least 1."
                         Class="mb-4" />

        <MudDatePicker @bind-Date="_deadlineDate"
                       Label="Enrollment Deadline"
                       Required="true"
                       MinDate="DateTime.Today.AddDays(1)"
                       Class="mb-6" />

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="@Submit"
                       Disabled="@(!_isValid || _submitting)">
                @(_submitting ? "Creating..." : "Create Course")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="@Cancel">
                Cancel
            </MudButton>
        </MudStack>

    </MudForm>
</MudPaper>

@code {
    private CreateCourseRequest _model = new();
    private DateTime? _deadlineDate = DateTime.Today.AddDays(30);
    private MudForm _form = default!;
    private bool _isValid;
    private bool _submitting;

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new BreadcrumbItem("Dashboard", href: "/"),
        new BreadcrumbItem("Courses", href: "/courses"),
        new BreadcrumbItem("Create", href: null, disabled: true)
    ];

    private void Cancel() => Nav.NavigateTo("/courses");

    private async Task Submit()
    {
        await _form.Validate();
        if (!_isValid) return;

        _model.EnrollmentDeadline = (_deadlineDate ?? DateTime.Today.AddDays(1)).ToUniversalTime();
        _submitting = true;

        var id = await Api.CreateCourseAsync(_model);
        _submitting = false;

        if (id.HasValue)
        {
            Snackbar.Add("Course created successfully!", Severity.Success);
            Nav.NavigateTo("/courses");
        }
        else
        {
            Snackbar.Add("Failed to create course. Check your inputs and try again.", Severity.Error);
        }
    }
}
