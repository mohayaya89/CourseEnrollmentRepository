@page "/login"
@inject AuthService AuthService
@inject NavigationManager Nav

<MudPaper Class="pa-6" MaxWidth="400px" Style="margin: auto; margin-top: 4rem;">
    <MudText Typo="Typo.h5" Class="mb-4">Sign In</MudText>

    <EditForm Model="_model" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <MudTextField @bind-Value="_model.Email"
                      Label="Email"
                      InputType="InputType.Email"
                      Variant="Variant.Outlined"
                      Class="mb-3" />

        <MudTextField @bind-Value="_model.Password"
                      Label="Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Class="mb-4" />

        @if (_errors.Length > 0)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_errors[0]</MudAlert>
        }

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Disabled="_loading">
            @(_loading ? "Signing in…" : "Sign In")
        </MudButton>
    </EditForm>

    <MudText Typo="Typo.body2" Class="mt-3 text-center">
        No account? <MudLink Href="/register">Register</MudLink>
    </MudText>
</MudPaper>

@code {
    private readonly LoginFormModel _model = new();
    private string[] _errors = [];
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _errors = [];

        var (success, errors) = await AuthService.LoginAsync(new LoginRequest(_model.Email, _model.Password));

        if (success)
            Nav.NavigateTo("/");
        else
            _errors = errors;

        _loading = false;
    }

    private class LoginFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = string.Empty;
    }
}
