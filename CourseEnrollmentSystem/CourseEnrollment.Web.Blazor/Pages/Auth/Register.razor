@page "/register"
@inject AuthService AuthService
@inject NavigationManager Nav

<MudPaper Class="pa-6" MaxWidth="400px" Style="margin: auto; margin-top: 4rem;">
    <MudText Typo="Typo.h5" Class="mb-4">Create Account</MudText>

    <EditForm Model="_model" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <MudTextField @bind-Value="_model.FirstName"
                      Label="First Name"
                      Variant="Variant.Outlined"
                      Class="mb-3" />

        <MudTextField @bind-Value="_model.LastName"
                      Label="Last Name"
                      Variant="Variant.Outlined"
                      Class="mb-3" />

        <MudTextField @bind-Value="_model.Email"
                      Label="Email"
                      InputType="InputType.Email"
                      Variant="Variant.Outlined"
                      Class="mb-3" />

        <MudTextField @bind-Value="_model.Password"
                      Label="Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Class="mb-4" />

        @if (_errors.Length > 0)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_errors[0]</MudAlert>
        }

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Disabled="_loading">
            @(_loading ? "Creating account…" : "Register")
        </MudButton>
    </EditForm>

    <MudText Typo="Typo.body2" Class="mt-3 text-center">
        Already have an account? <MudLink Href="/login">Sign In</MudLink>
    </MudText>
</MudPaper>

@code {
    private readonly RegisterFormModel _model = new();
    private string[] _errors = [];
    private bool _loading;

    private async Task HandleRegister()
    {
        _loading = true;
        _errors = [];

        var (success, errors) = await AuthService.RegisterAsync(
            new RegisterStudentRequest(
                _model.FirstName, _model.LastName, _model.Email, _model.Password));

        if (success)
            Nav.NavigateTo("/");
        else
            _errors = errors;

        _loading = false;
    }

    private class RegisterFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FirstName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string LastName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public string Password { get; set; } = string.Empty;
    }
}
